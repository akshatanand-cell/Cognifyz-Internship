<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Cognifyz - Weather App</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }

        body {
            font-family: 'Segoe UI', sans-serif;
            background: linear-gradient(135deg, #1a1a2e, #16213e, #0f3460);
            min-height: 100vh;
            padding: 40px 20px;
        }

        .main {
            max-width: 800px;
            margin: 0 auto;
        }

        /* Header */
        .header {
            text-align: center;
            color: white;
            margin-bottom: 40px;
        }

        .header h1 {
            font-size: 2.5rem;
            font-weight: bold;
        }

        .header h1 span { color: #00d4ff; }
        .header p { color: #aaa; margin-top: 10px; }

        /* Search box */
        .search-card {
            background: rgba(255,255,255,0.1);
            backdrop-filter: blur(10px);
            border-radius: 20px;
            padding: 30px;
            margin-bottom: 30px;
            border: 1px solid rgba(255,255,255,0.1);
        }

        .search-form {
            display: flex;
            gap: 15px;
        }

        .search-input {
            flex: 1;
            padding: 15px 20px;
            border: 2px solid rgba(255,255,255,0.2);
            border-radius: 12px;
            background: rgba(255,255,255,0.1);
            color: white;
            font-size: 16px;
            outline: none;
            transition: all 0.3s;
        }

        .search-input::placeholder { color: #aaa; }
        .search-input:focus {
            border-color: #00d4ff;
            background: rgba(255,255,255,0.15);
        }

        .btn-search {
            padding: 15px 30px;
            background: #00d4ff;
            color: #1a1a2e;
            border: none;
            border-radius: 12px;
            font-size: 16px;
            font-weight: bold;
            cursor: pointer;
            transition: all 0.3s;
        }

        .btn-search:hover {
            transform: translateY(-2px);
            box-shadow: 0 5px 20px rgba(0,212,255,0.4);
        }

        /* Popular cities */
        .popular-cities {
            display: flex;
            gap: 10px;
            flex-wrap: wrap;
            margin-top: 15px;
        }

        .city-btn {
            padding: 6px 15px;
            background: rgba(255,255,255,0.1);
            color: #ccc;
            border: 1px solid rgba(255,255,255,0.2);
            border-radius: 20px;
            cursor: pointer;
            font-size: 13px;
            transition: all 0.3s;
            text-decoration: none;
        }

        .city-btn:hover {
            background: #00d4ff;
            color: #1a1a2e;
            border-color: #00d4ff;
        }

        /* Error box */
        .error-box {
            background: #ffebee;
            border-left: 4px solid #f44336;
            border-radius: 10px;
            padding: 15px 20px;
            margin-bottom: 20px;
            color: #c62828;
            font-size: 14px;
        }

        /* Weather card */
        .weather-card {
            background: rgba(255,255,255,0.1);
            backdrop-filter: blur(10px);
            border-radius: 20px;
            padding: 40px;
            margin-bottom: 25px;
            border: 1px solid rgba(255,255,255,0.1);
            color: white;
            animation: fadeIn 0.5s ease;
        }

        @keyframes fadeIn {
            from { opacity: 0; transform: translateY(20px); }
            to { opacity: 1; transform: translateY(0); }
        }

        .weather-top {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 30px;
        }

        .city-name {
            font-size: 2rem;
            font-weight: bold;
        }

        .country {
            color: #00d4ff;
            font-size: 1rem;
            margin-top: 5px;
        }

        .weather-icon {
            font-size: 80px;
        }

        .temperature {
            font-size: 5rem;
            font-weight: bold;
            color: #00d4ff;
            line-height: 1;
        }

        .feels-like {
            color: #aaa;
            font-size: 14px;
            margin-top: 5px;
        }

        .weather-desc {
            font-size: 1.2rem;
            color: #ccc;
            text-transform: capitalize;
            margin-top: 10px;
        }

        /* Weather details grid */
        .details-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(140px, 1fr));
            gap: 15px;
            margin-top: 30px;
        }

        .detail-item {
            background: rgba(255,255,255,0.08);
            border-radius: 12px;
            padding: 20px 15px;
            text-align: center;
        }

        .detail-icon { font-size: 24px; margin-bottom: 8px; }
        .detail-value {
            font-size: 1.3rem;
            font-weight: bold;
            color: #00d4ff;
        }
        .detail-label {
            font-size: 12px;
            color: #aaa;
            margin-top: 4px;
        }

        /* Forecast */
        .forecast-card {
            background: rgba(255,255,255,0.1);
            backdrop-filter: blur(10px);
            border-radius: 20px;
            padding: 30px;
            border: 1px solid rgba(255,255,255,0.1);
            color: white;
            margin-bottom: 25px;
        }

        .forecast-title {
            font-size: 1.2rem;
            font-weight: bold;
            margin-bottom: 20px;
            color: #00d4ff;
        }

        .forecast-grid {
            display: grid;
            grid-template-columns: repeat(5, 1fr);
            gap: 10px;
        }

        .forecast-item {
            background: rgba(255,255,255,0.08);
            border-radius: 12px;
            padding: 15px 10px;
            text-align: center;
        }

        .forecast-day {
            font-size: 12px;
            color: #aaa;
            margin-bottom: 8px;
        }

        .forecast-icon { font-size: 24px; margin-bottom: 8px; }

        .forecast-temp {
            font-size: 1.1rem;
            font-weight: bold;
            color: #00d4ff;
        }

        .forecast-desc {
            font-size: 11px;
            color: #aaa;
            margin-top: 5px;
            text-transform: capitalize;
        }

        /* API info */
        .api-info {
            background: rgba(255,255,255,0.05);
            border-radius: 15px;
            padding: 20px;
            color: #aaa;
            font-size: 13px;
            border: 1px solid rgba(255,255,255,0.1);
        }

        .api-info h6 {
            color: #00d4ff;
            margin-bottom: 10px;
        }

        .api-badge {
            display: inline-block;
            padding: 3px 10px;
            border-radius: 5px;
            font-size: 11px;
            font-weight: bold;
            margin-right: 5px;
        }

        .badge-get { background: #e8f5e9; color: #2e7d32; }
        .badge-limit { background: #fff3e0; color: #e65100; }

        @media (max-width: 600px) {
            .search-form { flex-direction: column; }
            .forecast-grid { grid-template-columns: repeat(3, 1fr); }
            .temperature { font-size: 3.5rem; }
        }
    </style>
</head>
<body>
    <div class="main">

        <!-- Header -->
        <div class="header">
            <h1>🌤️ <span>Weather</span> Dashboard</h1>
            <p>Real-time weather data powered by OpenWeatherMap API</p>
        </div>

        <!-- Search -->
        <div class="search-card">
            <form action="/weather" method="GET" class="search-form">
                <input
                    type="text"
                    name="city"
                    class="search-input"
                    placeholder="🔍 Search any city... (e.g. Mumbai, London, Tokyo)"
                    value="<%= city || '' %>"
                    required>
                <button type="submit" class="btn-search">
                    Search 🔍
                </button>
            </form>

            <!-- Popular cities -->
            <div class="popular-cities">
                <span style="color:#aaa; font-size:13px; align-self:center;">
                    Popular:
                </span>
                <a href="/weather?city=Mumbai" class="city-btn">🇮🇳 Mumbai</a>
                <a href="/weather?city=Delhi" class="city-btn">🇮🇳 Delhi</a>
                <a href="/weather?city=Patna" class="city-btn">🇮🇳 Patna</a>
                <a href="/weather?city=London" class="city-btn">🇬🇧 London</a>
                <a href="/weather?city=Tokyo" class="city-btn">🇯🇵 Tokyo</a>
                <a href="/weather?city=New York" class="city-btn">🇺🇸 New York</a>
            </div>
        </div>

        <!-- Error -->
        <% if (error) { %>
        <div class="error-box">⚠️ <%= error %></div>
        <% } %>

        <!-- Weather Results -->
        <% if (weather) { %>

        <!-- Main weather card -->
        <div class="weather-card">
            <div class="weather-top">
                <div>
                    <div class="city-name">
                        📍 <%= weather.name %>
                    </div>
                    <div class="country">
                        <%= weather.sys.country %> —
                        <%= new Date().toLocaleDateString('en-IN', 
                            { weekday: 'long', year: 'numeric', 
                              month: 'long', day: 'numeric' }) %>
                    </div>
                    <div class="weather-desc">
                        <%= weather.weather[0].description %>
                    </div>
                </div>
                <div style="text-align:center">
                    <div class="weather-icon">
                        <% 
                        const main = weather.weather[0].main;
                        let icon = '🌤️';
                        if (main === 'Clear') icon = '☀️';
                        else if (main === 'Clouds') icon = '☁️';
                        else if (main === 'Rain') icon = '🌧️';
                        else if (main === 'Thunderstorm') icon = '⛈️';
                        else if (main === 'Snow') icon = '❄️';
                        else if (main === 'Mist' || main === 'Fog') icon = '🌫️';
                        else if (main === 'Haze') icon = '🌫️';
                        else if (main === 'Drizzle') icon = '🌦️';
                        %>
                        <%= icon %>
                    </div>
                    <div class="temperature">
                        <%= Math.round(weather.main.temp) %>°C
                    </div>
                    <div class="feels-like">
                        Feels like <%= Math.round(weather.main.feels_like) %>°C
                    </div>
                </div>
            </div>

            <!-- Details grid -->
            <div class="details-grid">
                <div class="detail-item">
                    <div class="detail-icon">💧</div>
                    <div class="detail-value"><%= weather.main.humidity %>%</div>
                    <div class="detail-label">Humidity</div>
                </div>
                <div class="detail-item">
                    <div class="detail-icon">💨</div>
                    <div class="detail-value">
                        <%= Math.round(weather.wind.speed * 3.6) %> km/h
                    </div>
                    <div class="detail-label">Wind Speed</div>
                </div>
                <div class="detail-item">
                    <div class="detail-icon">🌡️</div>
                    <div class="detail-value">
                        <%= Math.round(weather.main.temp_max) %>°C
                    </div>
                    <div class="detail-label">Max Temp</div>
                </div>
                <div class="detail-item">
                    <div class="detail-icon">🥶</div>
                    <div class="detail-value">
                        <%= Math.round(weather.main.temp_min) %>°C
                    </div>
                    <div class="detail-label">Min Temp</div>
                </div>
                <div class="detail-item">
                    <div class="detail-icon">👁️</div>
                    <div class="detail-value">
                        <%= (weather.visibility / 1000).toFixed(1) %> km
                    </div>
                    <div class="detail-label">Visibility</div>
                </div>
                <div class="detail-item">
                    <div class="detail-icon">🔵</div>
                    <div class="detail-value">
                        <%= weather.main.pressure %> hPa
                    </div>
                    <div class="detail-label">Pressure</div>
                </div>
            </div>
        </div>

        <!-- 5 Day Forecast -->
        <% if (forecast) { %>
        <div class="forecast-card">
            <div class="forecast-title">📅 5-Day Forecast</div>
            <div class="forecast-grid">
                <% forecast.forEach(day => { %>
                <div class="forecast-item">
                    <div class="forecast-day">
                        <%= new Date(day.dt * 1000).toLocaleDateString('en-IN', 
                            { weekday: 'short', month: 'short', day: 'numeric' }) %>
                    </div>
                    <div class="forecast-icon">
                        <%
                        const fm = day.weather[0].main;
                        let fi = '🌤️';
                        if (fm === 'Clear') fi = '☀️';
                        else if (fm === 'Clouds') fi = '☁️';
                        else if (fm === 'Rain') fi = '🌧️';
                        else if (fm === 'Thunderstorm') fi = '⛈️';
                        else if (fm === 'Snow') fi = '❄️';
                        else if (fm === 'Mist' || fm === 'Fog') fi = '🌫️';
                        %>
                        <%= fi %>
                    </div>
                    <div class="forecast-temp">
                        <%= Math.round(day.main.temp) %>°C
                    </div>
                    <div class="forecast-desc">
                        <%= day.weather[0].description %>
                    </div>
                </div>
                <% }) %>
            </div>
        </div>
        <% } %>

        <% } %>

        <!-- API Info -->
        <div class="api-info">
            <h6>🌐 API Integration Info</h6>
            <p>
                <span class="api-badge badge-get">GET</span>
                /api/weather?city=Mumbai — JSON API endpoint
            </p>
            <p style="margin-top:8px">
                <span class="api-badge badge-limit">LIMIT</span>
                Rate limited to 10 requests per minute per IP
            </p>
            <p style="margin-top:8px; color:#666;">
                🔑 Powered by OpenWeatherMap API —
                External API integration with error handling
            </p>
        </div>

    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>