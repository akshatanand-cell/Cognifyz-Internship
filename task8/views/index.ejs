<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Cognifyz - Server Dashboard</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }

        body {
            font-family: 'Segoe UI', sans-serif;
            background: #0f0f1a;
            color: white;
            min-height: 100vh;
        }

        /* Navbar */
        .navbar {
            background: linear-gradient(135deg, #1a1a2e, #16213e);
            padding: 15px 30px;
            display: flex;
            justify-content: space-between;
            align-items: center;
            border-bottom: 1px solid rgba(0,212,255,0.2);
        }

        .navbar-brand {
            font-size: 22px;
            font-weight: bold;
            color: #00d4ff;
        }

        .server-status {
            display: flex;
            align-items: center;
            gap: 8px;
            font-size: 14px;
            color: #4CAF50;
        }

        .status-dot {
            width: 10px;
            height: 10px;
            border-radius: 50%;
            background: #4CAF50;
            animation: pulse 2s infinite;
        }

        @keyframes pulse {
            0% { box-shadow: 0 0 0 0 rgba(76,175,80,0.4); }
            70% { box-shadow: 0 0 0 10px rgba(76,175,80,0); }
            100% { box-shadow: 0 0 0 0 rgba(76,175,80,0); }
        }

        /* Main */
        .main { padding: 30px; }

        /* Page title */
        .page-title {
            margin-bottom: 30px;
        }

        .page-title h2 {
            font-size: 1.8rem;
            font-weight: bold;
        }

        .page-title h2 span { color: #00d4ff; }
        .page-title p { color: #666; font-size: 14px; margin-top: 5px; }

        /* Stats grid */
        .stats-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
            gap: 20px;
            margin-bottom: 30px;
        }

        .stat-card {
            background: #1a1a2e;
            border-radius: 15px;
            padding: 25px 20px;
            text-align: center;
            border: 1px solid rgba(0,212,255,0.1);
            transition: all 0.3s;
        }

        .stat-card:hover {
            border-color: #00d4ff;
            transform: translateY(-3px);
        }

        .stat-icon { font-size: 30px; margin-bottom: 10px; }

        .stat-number {
            font-size: 2rem;
            font-weight: bold;
            color: #00d4ff;
        }

        .stat-label {
            color: #666;
            font-size: 13px;
            margin-top: 5px;
        }

        /* Section cards */
        .section-card {
            background: #1a1a2e;
            border-radius: 15px;
            padding: 25px;
            margin-bottom: 25px;
            border: 1px solid rgba(0,212,255,0.1);
        }

        .section-title {
            font-size: 1.1rem;
            font-weight: bold;
            color: #00d4ff;
            margin-bottom: 20px;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        /* Middleware list */
        .middleware-item {
            display: flex;
            align-items: center;
            gap: 15px;
            padding: 15px;
            background: rgba(0,212,255,0.05);
            border-radius: 10px;
            margin-bottom: 10px;
            border-left: 3px solid #00d4ff;
        }

        .middleware-icon { font-size: 24px; }

        .middleware-name {
            font-weight: bold;
            color: white;
            font-size: 14px;
        }

        .middleware-desc {
            color: #666;
            font-size: 12px;
            margin-top: 3px;
        }

        .middleware-status {
            margin-left: auto;
            background: #e8f5e9;
            color: #2e7d32;
            padding: 4px 12px;
            border-radius: 20px;
            font-size: 12px;
            font-weight: bold;
        }

        /* Jobs */
        .job-item {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 15px;
            background: rgba(255,255,255,0.03);
            border-radius: 10px;
            margin-bottom: 10px;
            border-left: 3px solid #4CAF50;
        }

        .job-name {
            font-weight: bold;
            font-size: 14px;
        }

        .job-time {
            color: #666;
            font-size: 12px;
            margin-top: 3px;
        }

        .job-msg {
            color: #aaa;
            font-size: 12px;
        }

        .job-status {
            background: #e8f5e9;
            color: #2e7d32;
            padding: 4px 12px;
            border-radius: 20px;
            font-size: 12px;
            font-weight: bold;
        }

        /* API endpoints */
        .endpoint-item {
            display: flex;
            align-items: center;
            gap: 10px;
            padding: 10px 0;
            border-bottom: 1px solid rgba(255,255,255,0.05);
            font-size: 13px;
            color: #aaa;
        }

        .method-badge {
            padding: 3px 10px;
            border-radius: 5px;
            font-weight: bold;
            font-size: 11px;
            min-width: 65px;
            text-align: center;
        }

        .GET { background: #e8f5e9; color: #2e7d32; }
        .POST { background: #e3f2fd; color: #1565c0; }
        .DELETE { background: #ffebee; color: #c62828; }

        /* Cache info */
        .cache-stat {
            display: flex;
            justify-content: space-between;
            padding: 10px 0;
            border-bottom: 1px solid rgba(255,255,255,0.05);
            font-size: 14px;
        }

        .cache-stat span:first-child { color: #666; }
        .cache-stat span:last-child { color: #00d4ff; font-weight: bold; }

        /* Action buttons */
        .btn-action {
            padding: 8px 18px;
            border-radius: 8px;
            border: none;
            cursor: pointer;
            font-size: 13px;
            font-weight: bold;
            transition: all 0.3s;
        }

        .btn-primary-custom {
            background: #00d4ff;
            color: #1a1a2e;
        }

        .btn-danger-custom {
            background: #f44336;
            color: white;
        }

        .btn-success-custom {
            background: #4CAF50;
            color: white;
        }

        .btn-action:hover { opacity: 0.8; transform: translateY(-1px); }

        /* Log viewer */
        .log-viewer {
            background: #0a0a0f;
            border-radius: 10px;
            padding: 15px;
            font-family: monospace;
            font-size: 12px;
            color: #4CAF50;
            max-height: 200px;
            overflow-y: auto;
            border: 1px solid rgba(0,212,255,0.1);
        }

        .log-line { margin-bottom: 5px; }

        /* Toast */
        .toast-container {
            position: fixed;
            bottom: 20px;
            right: 20px;
            z-index: 9999;
        }

        /* Two column grid */
        .two-col {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 25px;
        }

        @media (max-width: 768px) {
            .two-col { grid-template-columns: 1fr; }
            .main { padding: 15px; }
        }

        /* Uptime badge */
        .uptime-badge {
            background: rgba(76,175,80,0.2);
            color: #4CAF50;
            padding: 5px 15px;
            border-radius: 20px;
            font-size: 13px;
        }

        /* Auto refresh */
        .refresh-badge {
            background: rgba(0,212,255,0.1);
            color: #00d4ff;
            padding: 4px 12px;
            border-radius: 20px;
            font-size: 12px;
        }
    </style>
</head>
<body>

    <!-- Navbar -->
    <div class="navbar">
        <div class="navbar-brand">🧠 Cognifyz Server</div>
        <div style="display:flex; gap:20px; align-items:center">
            <span class="uptime-badge">⏱️ Uptime: <%= uptime %>s</span>
            <div class="server-status">
                <div class="status-dot"></div>
                Server Online
            </div>
        </div>
    </div>

    <div class="main">

        <!-- Page title -->
        <div class="page-title">
            <h2>⚙️ <span>Advanced Server</span> Dashboard</h2>
            <p>Task 8 — Middleware, Background Jobs & Caching</p>
        </div>

        <!-- Stats -->
        <div class="stats-grid">
            <div class="stat-card">
                <div class="stat-icon">📊</div>
                <div class="stat-number"><%= requestStats.total %></div>
                <div class="stat-label">Total Requests</div>
            </div>
            <div class="stat-card">
                <div class="stat-icon">🟢</div>
                <div class="stat-number"><%= requestStats.get %></div>
                <div class="stat-label">GET Requests</div>
            </div>
            <div class="stat-card">
                <div class="stat-icon">🔵</div>
                <div class="stat-number"><%= requestStats.post %></div>
                <div class="stat-label">POST Requests</div>
            </div>
            <div class="stat-card">
                <div class="stat-icon">❌</div>
                <div class="stat-number"><%= requestStats.errors %></div>
                <div class="stat-label">Errors</div>
            </div>
            <div class="stat-card">
                <div class="stat-icon">💾</div>
                <div class="stat-number"><%= cacheStats.hits %></div>
                <div class="stat-label">Cache Hits</div>
            </div>
            <div class="stat-card">
                <div class="stat-icon">⚡</div>
                <div class="stat-number">3</div>
                <div class="stat-label">Active Jobs</div>
            </div>
        </div>

        <!-- Two column layout -->
        <div class="two-col">

            <!-- Middleware -->
            <div class="section-card">
                <div class="section-title">
                    🔧 Active Middleware
                </div>

                <div class="middleware-item">
                    <div class="middleware-icon">📝</div>
                    <div>
                        <div class="middleware-name">Morgan Logger</div>
                        <div class="middleware-desc">
                            Logs all HTTP requests to file and console
                        </div>
                    </div>
                    <span class="middleware-status">Active</span>
                </div>

                <div class="middleware-item">
                    <div class="middleware-icon">⏱️</div>
                    <div>
                        <div class="middleware-name">Request Timer</div>
                        <div class="middleware-desc">
                            Measures response time for every request
                        </div>
                    </div>
                    <span class="middleware-status">Active</span>
                </div>

                <div class="middleware-item">
                    <div class="middleware-icon">📊</div>
                    <div>
                        <div class="middleware-name">Request Counter</div>
                        <div class="middleware-desc">
                            Counts GET, POST, DELETE requests
                        </div>
                    </div>
                    <span class="middleware-status">Active</span>
                </div>

                <div class="middleware-item">
                    <div class="middleware-icon">💾</div>
                    <div>
                        <div class="middleware-name">Cache Middleware</div>
                        <div class="middleware-desc">
                            Caches API responses for 60 seconds
                        </div>
                    </div>
                    <span class="middleware-status">Active</span>
                </div>

                <div class="middleware-item">
                    <div class="middleware-icon">🛡️</div>
                    <div>
                        <div class="middleware-name">Error Handler</div>
                        <div class="middleware-desc">
                            Catches and handles all server errors
                        </div>
                    </div>
                    <span class="middleware-status">Active</span>
                </div>
            </div>

            <!-- Background Jobs -->
            <div class="section-card">
                <div class="section-title">
                    ⚡ Background Jobs
                    <button class="btn-action btn-primary-custom"
                        onclick="triggerJob()">
                        + Trigger Job
                    </button>
                </div>

                <% if (jobResults.length === 0) { %>
                <div style="text-align:center; padding:30px; color:#666;">
                    ⏳ Waiting for jobs to run...
                    <br>
                    <small>Jobs run every 15-30 seconds</small>
                </div>
                <% } else { %>
                <% jobResults.forEach(job => { %>
                <div class="job-item">
                    <div>
                        <div class="job-name">⚡ <%= job.name %></div>
                        <div class="job-time">🕐 <%= job.runAt %></div>
                        <div class="job-msg"><%= job.message %></div>
                    </div>
                    <span class="job-status">✅ Done</span>
                </div>
                <% }) %>
                <% } %>
            </div>

        </div>

        <!-- Two column layout 2 -->
        <div class="two-col">

            <!-- Cache Info -->
            <div class="section-card">
                <div class="section-title">
                    💾 Cache Statistics
                    <button class="btn-action btn-danger-custom"
                        onclick="clearCache()">
                        🗑️ Clear Cache
                    </button>
                </div>

                <div class="cache-stat">
                    <span>Cache Hits</span>
                    <span><%= cacheStats.hits %></span>
                </div>
                <div class="cache-stat">
                    <span>Cache Misses</span>
                    <span><%= cacheStats.misses %></span>
                </div>
                <div class="cache-stat">
                    <span>Cached Keys</span>
                    <span><%= cacheStats.keys %></span>
                </div>
                <div class="cache-stat">
                    <span>TTL</span>
                    <span>60 seconds</span>
                </div>
                <div class="cache-stat">
                    <span>Status</span>
                    <span style="color:#4CAF50">Active ✅</span>
                </div>

                <div style="margin-top:20px">
                    <button class="btn-action btn-primary-custom"
                        onclick="testCache()">
                        🧪 Test Cache
                    </button>
                </div>
            </div>

            <!-- API Endpoints -->
            <div class="section-card">
                <div class="section-title">🌐 API Endpoints</div>

                <div class="endpoint-item">
                    <span class="method-badge GET">GET</span>
                    <span>/api/stats — Server statistics</span>
                </div>
                <div class="endpoint-item">
                    <span class="method-badge GET">GET</span>
                    <span>/api/jobs — Background jobs</span>
                </div>
                <div class="endpoint-item">
                    <span class="method-badge POST">POST</span>
                    <span>/api/jobs/trigger — Trigger job</span>
                </div>
                <div class="endpoint-item">
                    <span class="method-badge GET">GET</span>
                    <span>/api/cache — Cache info</span>
                </div>
                <div class="endpoint-item">
                    <span class="method-badge DELETE">DELETE</span>
                    <span>/api/cache — Clear cache</span>
                </div>
                <div class="endpoint-item">
                    <span class="method-badge GET">GET</span>
                    <span>/api/logs — Request logs</span>
                </div>
            </div>

        </div>

        <!-- Log Viewer -->
        <div class="section-card">
            <div class="section-title">
                📋 Request Logs
                <div style="display:flex; gap:10px">
                    <button class="btn-action btn-success-custom"
                        onclick="loadLogs()">
                        🔄 Refresh Logs
                    </button>
                    <span class="refresh-badge">
                        Auto-refresh every 10s
                    </span>
                </div>
            </div>
            <div class="log-viewer" id="log-viewer">
                <div class="log-line">
                    📡 Server started — waiting for requests...
                </div>
            </div>
        </div>

    </div>

    <!-- Toast container -->
    <div class="toast-container" id="toast-container"></div>

    <script>
        // ===== LOAD LOGS =====
        async function loadLogs() {
            const res = await fetch('/api/logs');
            const data = await res.json();
            const viewer = document.getElementById('log-viewer');

            if (data.logs.length === 0) {
                viewer.innerHTML = '<div class="log-line">📡 No logs yet...</div>';
                return;
            }

            viewer.innerHTML = data.logs.map(log =>
                `<div class="log-line">📡 ${log}</div>`
            ).join('');
        }

        // ===== CLEAR CACHE =====
        async function clearCache() {
            const res = await fetch('/api/cache', { method: 'DELETE' });
            const data = await res.json();
            showToast('✅ Cache cleared!', 'success');
            setTimeout(() => location.reload(), 1000);
        }

        // ===== TEST CACHE =====
        async function testCache() {
            showToast('🔍 First request — Cache MISS...', 'info');
            await fetch('/api/stats');
            setTimeout(async () => {
                showToast('💾 Second request — Cache HIT!', 'success');
                await fetch('/api/stats');
                setTimeout(() => location.reload(), 500);
            }, 1000);
        }

        // ===== TRIGGER JOB =====
        async function triggerJob() {
            const jobName = prompt('Enter job name:', 'Custom Job');
            if (!jobName) return;

            const res = await fetch('/api/jobs/trigger', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ jobName })
            });
            const data = await res.json();
            showToast(`⚡ Job "${jobName}" triggered!`, 'success');
            setTimeout(() => location.reload(), 500);
        }

        // ===== TOAST =====
        function showToast(msg, type) {
            const colors = {
                success: '#4CAF50',
                error: '#f44336',
                info: '#00d4ff'
            };
            const toast = document.createElement('div');
            toast.style.cssText = `
                background: ${colors[type] || '#333'};
                color: white;
                padding: 12px 20px;
                border-radius: 10px;
                margin-top: 10px;
                font-size: 14px;
                font-weight: bold;
                animation: fadeIn 0.3s ease;
            `;
            toast.textContent = msg;
            document.getElementById('toast-container').appendChild(toast);
            setTimeout(() => toast.remove(), 3000);
        }

        // ===== AUTO REFRESH =====
        setInterval(loadLogs, 10000);
        loadLogs();
    </script>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>