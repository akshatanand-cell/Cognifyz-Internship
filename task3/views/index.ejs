<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Cognifyz Technologies</title>

    <!-- Bootstrap CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    
    <!-- Font Awesome Icons -->
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet">

    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }
        
        body {
            font-family: 'Segoe UI', sans-serif;
            scroll-behavior: smooth;
        }

        /* ===== NAVBAR ===== */
        .navbar {
            background: rgba(0,0,0,0.9) !important;
            padding: 15px 0;
            position: fixed;
            width: 100%;
            top: 0;
            z-index: 1000;
            transition: all 0.3s;
        }

        .navbar-brand {
            font-size: 24px;
            font-weight: bold;
            color: #00d4ff !important;
        }

        .nav-link {
            color: white !important;
            margin: 0 10px;
            transition: color 0.3s;
        }

        .nav-link:hover { color: #00d4ff !important; }

        /* ===== HERO SECTION ===== */
        .hero {
            background: linear-gradient(135deg, #0f0c29, #302b63, #24243e);
            min-height: 100vh;
            display: flex;
            align-items: center;
            text-align: center;
            color: white;
            padding-top: 80px;
        }

        .hero h1 {
            font-size: 3.5rem;
            font-weight: bold;
            margin-bottom: 20px;
            animation: fadeInDown 1s ease;
        }

        .hero h1 span { color: #00d4ff; }

        .hero p {
            font-size: 1.2rem;
            color: #ccc;
            margin-bottom: 40px;
            animation: fadeInUp 1s ease;
        }

        .hero-btn {
            padding: 15px 40px;
            background: #00d4ff;
            color: #0f0c29;
            border: none;
            border-radius: 50px;
            font-size: 18px;
            font-weight: bold;
            text-decoration: none;
            transition: all 0.3s;
            animation: fadeIn 1.5s ease;
        }

        .hero-btn:hover {
            background: white;
            color: #302b63;
            transform: translateY(-3px);
            box-shadow: 0 10px 30px rgba(0,212,255,0.4);
        }

        /* ===== ANIMATIONS ===== */
        @keyframes fadeInDown {
            from { opacity: 0; transform: translateY(-50px); }
            to { opacity: 1; transform: translateY(0); }
        }

        @keyframes fadeInUp {
            from { opacity: 0; transform: translateY(50px); }
            to { opacity: 1; transform: translateY(0); }
        }

        @keyframes fadeIn {
            from { opacity: 0; }
            to { opacity: 1; }
        }

        /* ===== SERVICES SECTION ===== */
        .services {
            padding: 100px 0;
            background: #f8f9fa;
        }

        .section-title {
            text-align: center;
            margin-bottom: 60px;
        }

        .section-title h2 {
            font-size: 2.5rem;
            font-weight: bold;
            color: #333;
        }

        .section-title p {
            color: #888;
            font-size: 1.1rem;
            margin-top: 10px;
        }

        .section-title h2 span { color: #00d4ff; }

        .service-card {
            background: white;
            border-radius: 15px;
            padding: 40px 30px;
            text-align: center;
            box-shadow: 0 5px 30px rgba(0,0,0,0.08);
            transition: all 0.3s;
            height: 100%;
        }

        .service-card:hover {
            transform: translateY(-10px);
            box-shadow: 0 20px 50px rgba(0,0,0,0.15);
        }

        .service-icon {
            font-size: 50px;
            margin-bottom: 20px;
        }

        .service-card h4 {
            font-size: 1.3rem;
            font-weight: bold;
            color: #333;
            margin-bottom: 15px;
        }

        .service-card p { color: #777; line-height: 1.7; }

        /* ===== STATS SECTION ===== */
        .stats {
            background: linear-gradient(135deg, #0f0c29, #302b63);
            padding: 80px 0;
            color: white;
            text-align: center;
        }

        .stat-number {
            font-size: 3rem;
            font-weight: bold;
            color: #00d4ff;
        }

        .stat-label {
            font-size: 1rem;
            color: #ccc;
            margin-top: 5px;
        }

        /* ===== TEAM SECTION ===== */
        .team {
            padding: 100px 0;
            background: white;
        }

        .team-card {
            text-align: center;
            padding: 30px;
            border-radius: 15px;
            transition: all 0.3s;
        }

        .team-card:hover {
            box-shadow: 0 10px 40px rgba(0,0,0,0.1);
            transform: translateY(-5px);
        }

        .team-avatar {
            width: 100px;
            height: 100px;
            border-radius: 50%;
            background: linear-gradient(135deg, #00d4ff, #302b63);
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 0 auto 20px;
            font-size: 40px;
            color: white;
        }

        .team-card h5 {
            font-weight: bold;
            color: #333;
            margin-bottom: 5px;
        }

        .team-card p { color: #00d4ff; font-size: 14px; }

        /* ===== CONTACT SECTION ===== */
        .contact {
            padding: 100px 0;
            background: #f8f9fa;
        }

        .contact-form {
            background: white;
            padding: 50px;
            border-radius: 20px;
            box-shadow: 0 10px 50px rgba(0,0,0,0.1);
        }

        .form-control {
            padding: 12px 15px;
            border: 2px solid #eee;
            border-radius: 8px;
            font-size: 14px;
            transition: border-color 0.3s;
        }

        .form-control:focus {
            border-color: #00d4ff;
            box-shadow: none;
        }

        .btn-submit {
            width: 100%;
            padding: 15px;
            background: linear-gradient(135deg, #0f0c29, #302b63);
            color: white;
            border: none;
            border-radius: 8px;
            font-size: 16px;
            font-weight: bold;
            cursor: pointer;
            transition: all 0.3s;
        }

        .btn-submit:hover {
            transform: translateY(-2px);
            box-shadow: 0 10px 30px rgba(48,43,99,0.4);
        }

        /* ===== FOOTER ===== */
        footer {
            background: #0f0c29;
            color: #ccc;
            text-align: center;
            padding: 30px;
        }

        footer span { color: #00d4ff; }

        /* ===== RESPONSIVE ===== */
        @media (max-width: 768px) {
            .hero h1 { font-size: 2.5rem; }
            .contact-form { padding: 30px 20px; }
        }

        @media (max-width: 480px) {
            .hero h1 { font-size: 1.8rem; }
            .stat-number { font-size: 2rem; }
        }
    </style>
</head>
<body>

    <!-- ===== NAVBAR ===== -->
    <nav class="navbar navbar-expand-lg">
        <div class="container">
            <a class="navbar-brand" href="#">
                🧠 Cognifyz
            </a>
            <button class="navbar-toggler" type="button" 
                data-bs-toggle="collapse" 
                data-bs-target="#navbarNav">
                <span class="navbar-toggler-icon" 
                style="filter: invert(1)"></span>
            </button>
            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav ms-auto">
                    <li class="nav-item">
                        <a class="nav-link" href="#services">Services</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="#stats">Stats</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="#team">Team</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="#contact">Contact</a>
                    </li>
                </ul>
            </div>
        </div>
    </nav>

    <!-- ===== HERO SECTION ===== -->
    <section class="hero" id="home">
        <div class="container">
            <h1>Where <span>Data</span> Meets<br>Intelligence</h1>
            <p>Cognifyz Technologies — Leading AI, ML and Data Science solutions<br>
            for the modern world</p>
            <a href="#services" class="hero-btn">Explore Our Services</a>
        </div>
    </section>

    <!-- ===== SERVICES SECTION ===== -->
    <section class="services" id="services">
        <div class="container">
            <div class="section-title">
                <h2>Our <span>Services</span></h2>
                <p>Cutting-edge technology solutions for your business</p>
            </div>
            <div class="row g-4">
                <div class="col-md-4">
                    <div class="service-card">
                        <div class="service-icon">🤖</div>
                        <h4>Artificial Intelligence</h4>
                        <p>Build intelligent systems that learn, adapt and solve complex problems using state-of-the-art AI models.</p>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="service-card">
                        <div class="service-icon">📊</div>
                        <h4>Data Analytics</h4>
                        <p>Transform raw data into powerful insights that drive strategic decisions and business growth.</p>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="service-card">
                        <div class="service-icon">🧠</div>
                        <h4>Machine Learning</h4>
                        <p>Develop predictive models and algorithms that continuously improve from experience and data.</p>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="service-card">
                        <div class="service-icon">☁️</div>
                        <h4>Cloud Solutions</h4>
                        <p>Scalable and secure cloud infrastructure solutions tailored to your business requirements.</p>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="service-card">
                        <div class="service-icon">🔒</div>
                        <h4>Cybersecurity</h4>
                        <p>Protect your digital assets with enterprise-grade security solutions and threat detection.</p>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="service-card">
                        <div class="service-icon">📱</div>
                        <h4>App Development</h4>
                        <p>Create stunning mobile and web applications with modern technologies and beautiful design.</p>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- ===== STATS SECTION ===== -->
    <section class="stats" id="stats">
        <div class="container">
            <div class="row">
                <div class="col-md-3 col-6 mb-4">
                    <div class="stat-number">500+</div>
                    <div class="stat-label">Projects Completed</div>
                </div>
                <div class="col-md-3 col-6 mb-4">
                    <div class="stat-number">200+</div>
                    <div class="stat-label">Happy Clients</div>
                </div>
                <div class="col-md-3 col-6 mb-4">
                    <div class="stat-number">50+</div>
                    <div class="stat-label">Team Members</div>
                </div>
                <div class="col-md-3 col-6 mb-4">
                    <div class="stat-number">5+</div>
                    <div class="stat-label">Years Experience</div>
                </div>
            </div>
        </div>
    </section>

    <!-- ===== TEAM SECTION ===== -->
    <section class="team" id="team">
        <div class="container">
            <div class="section-title">
                <h2>Our <span>Team</span></h2>
                <p>Meet the brilliant minds behind Cognifyz</p>
            </div>
            <div class="row g-4">
                <div class="col-md-3 col-6">
                    <div class="team-card">
                        <div class="team-avatar">👨‍💼</div>
                        <h5>Rahul Sharma</h5>
                        <p>CEO & Founder</p>
                    </div>
                </div>
                <div class="col-md-3 col-6">
                    <div class="team-card">
                        <div class="team-avatar">👩‍💻</div>
                        <h5>Priya Patel</h5>
                        <p>Lead Data Scientist</p>
                    </div>
                </div>
                <div class="col-md-3 col-6">
                    <div class="team-card">
                        <div class="team-avatar">👨‍🔬</div>
                        <h5>Arjun Mehta</h5>
                        <p>AI Engineer</p>
                    </div>
                </div>
                <div class="col-md-3 col-6">
                    <div class="team-card">
                        <div class="team-avatar">👩‍🎨</div>
                        <h5>Sneha Gupta</h5>
                        <p>UI/UX Designer</p>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- ===== CONTACT SECTION ===== -->
    <section class="contact" id="contact">
        <div class="container">
            <div class="section-title">
                <h2>Contact <span>Us</span></h2>
                <p>Get in touch with our team</p>
            </div>
            <div class="row justify-content-center">
                <div class="col-md-8">
                    <div class="contact-form">
                        <form action="/contact" method="POST">
                            <div class="mb-3">
                                <label class="form-label fw-bold">Your Name</label>
                                <input type="text" 
                                    class="form-control" 
                                    name="name" 
                                    placeholder="Enter your name"
                                    required>
                            </div>
                            <div class="mb-3">
                                <label class="form-label fw-bold">Email Address</label>
                                <input type="email" 
                                    class="form-control" 
                                    name="email" 
                                    placeholder="Enter your email"
                                    required>
                            </div>
                            <div class="mb-4">
                                <label class="form-label fw-bold">Message</label>
                                <textarea 
                                    class="form-control" 
                                    name="message" 
                                    rows="5" 
                                    placeholder="Write your message here"
                                    required></textarea>
                            </div>
                            <button type="submit" class="btn-submit">
                                Send Message 🚀
                            </button>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- ===== FOOTER ===== -->
    <footer>
        <p>© 2026 <span>Cognifyz Technologies</span> — Where Data Meets Intelligence</p>
        <p style="margin-top:10px; font-size:13px;">
            Built by <span>Akshat Anand</span> | Full Stack Development Internship
        </p>
    </footer>

    <!-- Bootstrap JS -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>

</body>
</html>