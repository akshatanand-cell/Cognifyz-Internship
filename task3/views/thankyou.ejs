<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Cognifyz - Thank You!</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }

        body {
            font-family: 'Segoe UI', sans-serif;
            background: linear-gradient(135deg, #0f0c29, #302b63, #24243e);
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 20px;
        }

        .card {
            background: white;
            border-radius: 20px;
            padding: 50px 40px;
            max-width: 550px;
            width: 100%;
            text-align: center;
            box-shadow: 0 20px 60px rgba(0,0,0,0.3);
            animation: popIn 0.5s ease;
        }

        @keyframes popIn {
            from { opacity: 0; transform: scale(0.8); }
            to { opacity: 1; transform: scale(1); }
        }

        .success-icon {
            font-size: 80px;
            margin-bottom: 20px;
            animation: bounce 1s infinite alternate;
        }

        @keyframes bounce {
            from { transform: translateY(0); }
            to { transform: translateY(-10px); }
        }

        h1 {
            font-size: 2rem;
            font-weight: bold;
            color: #302b63;
            margin-bottom: 10px;
        }

        .subtitle {
            color: #888;
            margin-bottom: 30px;
            font-size: 15px;
        }

        .info-box {
            background: #f8f9fa;
            border-left: 4px solid #00d4ff;
            border-radius: 10px;
            padding: 20px;
            text-align: left;
            margin-bottom: 30px;
        }

        .info-row {
            display: flex;
            padding: 8px 0;
            border-bottom: 1px solid #eee;
            font-size: 14px;
            gap: 10px;
        }

        .info-row:last-child {
            border-bottom: none;
        }

        .info-label {
            font-weight: bold;
            color: #555;
            min-width: 80px;
        }

        .info-value { color: #333; }

        .btn-home {
            display: inline-block;
            padding: 14px 40px;
            background: linear-gradient(135deg, #0f0c29, #302b63);
            color: white;
            text-decoration: none;
            border-radius: 50px;
            font-size: 15px;
            font-weight: bold;
            transition: all 0.3s;
        }

        .btn-home:hover {
            color: white;
            transform: translateY(-3px);
            box-shadow: 0 10px 30px rgba(48,43,99,0.4);
        }

        .footer-text {
            margin-top: 25px;
            font-size: 13px;
            color: #aaa;
        }
    </style>
</head>
<body>
    <div class="card">

        <div class="success-icon">🎉</div>

        <h1>Message Received!</h1>
        <p class="subtitle">Thank you for contacting Cognifyz Technologies.<br>
        We'll get back to you within 24 hours.</p>

        <div class="info-box">
            <div class="info-row">
                <span class="info-label">👤 Name</span>
                <span class="info-value"><%= name %></span>
            </div>
            <div class="info-row">
                <span class="info-label">📧 Email</span>
                <span class="info-value"><%= email %></span>
            </div>
            <div class="info-row">
                <span class="info-label">💬 Message</span>
                <span class="info-value"><%= message %></span>
            </div>
        </div>

        <a href="/" class="btn-home">← Back to Home</a>

        <p class="footer-text">
            © 2026 Cognifyz Technologies — Where Data Meets Intelligence
        </p>

    </div>
</body>
</html>