<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Cognifyz - Dynamic Form</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }

        body {
            font-family: 'Segoe UI', sans-serif;
            background: linear-gradient(135deg, #1a1a2e, #16213e, #0f3460);
            min-height: 100vh;
            padding: 40px 20px;
        }

        .main-container {
            max-width: 800px;
            margin: 0 auto;
        }

        /* Header */
        .header {
            text-align: center;
            margin-bottom: 40px;
            color: white;
        }

        .header h1 {
            font-size: 2.5rem;
            font-weight: bold;
        }

        .header h1 span { color: #00d4ff; }
        .header p { color: #aaa; margin-top: 10px; }

        /* Tabs */
        .tab-buttons {
            display: flex;
            background: rgba(255,255,255,0.1);
            border-radius: 15px;
            padding: 5px;
            margin-bottom: 30px;
            gap: 5px;
        }

        .tab-btn {
            flex: 1;
            padding: 12px;
            border: none;
            border-radius: 10px;
            background: transparent;
            color: #aaa;
            font-size: 15px;
            cursor: pointer;
            transition: all 0.3s;
            font-weight: bold;
        }

        .tab-btn.active {
            background: #00d4ff;
            color: #1a1a2e;
        }

        .tab-btn:hover:not(.active) {
            background: rgba(255,255,255,0.1);
            color: white;
        }

        /* Tab content */
        .tab-content-box {
            display: none;
            animation: fadeIn 0.3s ease;
        }

        .tab-content-box.active { display: block; }

        @keyframes fadeIn {
            from { opacity: 0; transform: translateY(10px); }
            to { opacity: 1; transform: translateY(0); }
        }

        /* Form card */
        .form-card {
            background: white;
            border-radius: 20px;
            padding: 40px;
            box-shadow: 0 20px 60px rgba(0,0,0,0.3);
        }

        .form-group { margin-bottom: 25px; }

        label {
            display: block;
            font-weight: bold;
            color: #333;
            margin-bottom: 8px;
            font-size: 14px;
        }

        .input-wrapper { position: relative; }

        input[type="text"],
        input[type="email"],
        input[type="password"],
        input[type="tel"],
        select,
        textarea {
            width: 100%;
            padding: 12px 15px;
            border: 2px solid #eee;
            border-radius: 10px;
            font-size: 14px;
            transition: all 0.3s;
            outline: none;
        }

        input:focus, select:focus, textarea:focus {
            border-color: #00d4ff;
        }

        input.valid { border-color: #4CAF50; }
        input.invalid { border-color: #f44336; }

        .validation-msg {
            font-size: 12px;
            margin-top: 5px;
            display: none;
        }

        .validation-msg.show { display: block; }
        .validation-msg.success { color: #4CAF50; }
        .validation-msg.error { color: #f44336; }

        /* Password field */
        .password-wrapper { position: relative; }

        .toggle-password {
            position: absolute;
            right: 12px;
            top: 50%;
            transform: translateY(-50%);
            background: none;
            border: none;
            cursor: pointer;
            font-size: 18px;
            color: #888;
        }

        /* Password strength */
        .strength-container { margin-top: 8px; }

        .strength-bars {
            display: flex;
            gap: 5px;
            margin-bottom: 5px;
        }

        .strength-bar {
            height: 5px;
            flex: 1;
            border-radius: 3px;
            background: #eee;
            transition: all 0.3s;
        }

        .strength-bar.weak { background: #f44336; }
        .strength-bar.medium { background: #ff9800; }
        .strength-bar.strong { background: #4CAF50; }

        .strength-text {
            font-size: 12px;
            color: #888;
        }

        /* Character counter */
        .char-counter {
            font-size: 12px;
            color: #aaa;
            text-align: right;
            margin-top: 4px;
        }

        .char-counter.warning { color: #ff9800; }
        .char-counter.danger { color: #f44336; }

        /* Checkboxes */
        .checkbox-group {
            display: flex;
            flex-wrap: wrap;
            gap: 10px;
        }

        .checkbox-item {
            display: flex;
            align-items: center;
            gap: 6px;
            background: #f8f9fa;
            padding: 8px 15px;
            border-radius: 20px;
            cursor: pointer;
            transition: all 0.3s;
            font-size: 13px;
        }

        .checkbox-item:hover { background: #e3f2fd; }

        .checkbox-item input[type="checkbox"] {
            width: auto;
            border: none;
            padding: 0;
        }

        /* Progress bar */
        .form-progress {
            margin-bottom: 25px;
        }

        .progress-label {
            display: flex;
            justify-content: space-between;
            margin-bottom: 8px;
            font-size: 13px;
            color: #555;
        }

        .progress {
            height: 8px;
            border-radius: 4px;
            background: #eee;
        }

        .progress-bar {
            background: linear-gradient(90deg, #00d4ff, #4CAF50);
            border-radius: 4px;
            transition: width 0.3s;
        }

        /* Submit button */
        .btn-submit {
            width: 100%;
            padding: 15px;
            background: linear-gradient(135deg, #1a1a2e, #0f3460);
            color: white;
            border: none;
            border-radius: 10px;
            font-size: 16px;
            font-weight: bold;
            cursor: pointer;
            transition: all 0.3s;
        }

        .btn-submit:hover {
            transform: translateY(-2px);
            box-shadow: 0 10px 30px rgba(0,0,0,0.3);
        }

        .btn-submit:disabled {
            opacity: 0.6;
            cursor: not-allowed;
            transform: none;
        }

        /* Error box */
        .error-box {
            background: #ffebee;
            border-left: 4px solid #f44336;
            border-radius: 8px;
            padding: 15px;
            margin-bottom: 20px;
            display: none;
        }

        .error-box.show { display: block; }
        .error-box p { color: #c62828; font-size: 13px; margin: 3px 0; }

        /* Success box */
        .success-box {
            background: #e8f5e9;
            border-left: 4px solid #4CAF50;
            border-radius: 8px;
            padding: 15px;
            margin-bottom: 20px;
            display: none;
            text-align: center;
        }

        .success-box.show { display: block; }
        .success-box h3 { color: #2e7d32; }
        .success-box p { color: #388e3c; font-size: 14px; }

        /* Users table */
        .users-card {
            background: white;
            border-radius: 20px;
            padding: 30px;
            box-shadow: 0 20px 60px rgba(0,0,0,0.3);
        }

        .users-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 20px;
        }

        .users-header h3 { color: #333; font-weight: bold; }

        .badge-count {
            background: #00d4ff;
            color: #1a1a2e;
            padding: 5px 15px;
            border-radius: 20px;
            font-weight: bold;
            font-size: 14px;
        }

        .user-card {
            background: #f8f9fa;
            border-radius: 12px;
            padding: 20px;
            margin-bottom: 15px;
            display: flex;
            justify-content: space-between;
            align-items: center;
            transition: all 0.3s;
            animation: slideIn 0.3s ease;
        }

        @keyframes slideIn {
            from { opacity: 0; transform: translateX(-20px); }
            to { opacity: 1; transform: translateX(0); }
        }

        .user-card:hover { background: #e3f2fd; }

        .user-info h5 {
            color: #333;
            font-weight: bold;
            margin-bottom: 5px;
        }

        .user-info p {
            color: #777;
            font-size: 13px;
            margin: 2px 0;
        }

        .btn-delete {
            background: #ffebee;
            color: #f44336;
            border: none;
            padding: 8px 15px;
            border-radius: 8px;
            cursor: pointer;
            font-size: 13px;
            transition: all 0.3s;
        }

        .btn-delete:hover { background: #f44336; color: white; }

        .empty-state {
            text-align: center;
            padding: 40px;
            color: #aaa;
        }

        .empty-state div { font-size: 50px; margin-bottom: 15px; }

        /* Radio buttons */
        .radio-group {
            display: flex;
            gap: 15px;
            flex-wrap: wrap;
        }

        .radio-item {
            display: flex;
            align-items: center;
            gap: 6px;
            cursor: pointer;
            font-size: 14px;
        }

        .radio-item input { width: auto; padding: 0; border: none; }
    </style>
</head>
<body>
    <div class="main-container">

        <!-- Header -->
        <div class="header">
            <h1>🧠 <span>Cognifyz</span> Portal</h1>
            <p>Dynamic Form with Advanced Validation</p>
        </div>

        <!-- Tabs -->
        <div class="tab-buttons">
            <button class="tab-btn active" onclick="showTab('register')">
                📝 Register
            </button>
            <button class="tab-btn" onclick="showTab('users')">
                👥 View Users
            </button>
        </div>

        <!-- REGISTER TAB -->
        <div class="tab-content-box active" id="tab-register">
            <div class="form-card">

                <!-- Progress bar -->
                <div class="form-progress">
                    <div class="progress-label">
                        <span>Form Progress</span>
                        <span id="progress-text">0%</span>
                    </div>
                    <div class="progress">
                        <div class="progress-bar" id="progress-bar" style="width:0%"></div>
                    </div>
                </div>

                <!-- Error box -->
                <div class="error-box" id="error-box"></div>

                <!-- Success box -->
                <div class="success-box" id="success-box">
                    <h3>🎉 Registration Successful!</h3>
                    <p id="success-msg"></p>
                </div>

                <div id="register-form">
                    <!-- Name -->
                    <div class="form-group">
                        <label>👤 Full Name</label>
                        <input type="text" id="name" 
                            placeholder="Enter your full name"
                            oninput="validateName(this)">
                        <div class="validation-msg" id="name-msg"></div>
                    </div>

                    <!-- Email -->
                    <div class="form-group">
                        <label>📧 Email Address</label>
                        <input type="text" id="email"
                            placeholder="Enter your email"
                            oninput="validateEmail(this)">
                        <div class="validation-msg" id="email-msg"></div>
                    </div>

                    <!-- Phone -->
                    <div class="form-group">
                        <label>📱 Phone Number</label>
                        <input type="tel" id="phone"
                            placeholder="Enter 10 digit number"
                            maxlength="10"
                            oninput="validatePhone(this)">
                        <div class="validation-msg" id="phone-msg"></div>
                    </div>

                    <!-- Password -->
                    <div class="form-group">
                        <label>🔐 Password</label>
                        <div class="password-wrapper">
                            <input type="password" id="password"
                                placeholder="Create strong password"
                                oninput="validatePassword(this)">
                            <button class="toggle-password" 
                                onclick="togglePassword()" 
                                type="button" id="toggle-btn">👁️</button>
                        </div>
                        <div class="strength-container">
                            <div class="strength-bars">
                                <div class="strength-bar" id="bar1"></div>
                                <div class="strength-bar" id="bar2"></div>
                                <div class="strength-bar" id="bar3"></div>
                                <div class="strength-bar" id="bar4"></div>
                            </div>
                            <div class="strength-text" id="strength-text">
                                Enter a password
                            </div>
                        </div>
                        <div class="validation-msg" id="password-msg"></div>
                    </div>

                    <!-- Gender -->
                    <div class="form-group">
                        <label>⚧ Gender</label>
                        <div class="radio-group">
                            <label class="radio-item">
                                <input type="radio" name="gender" 
                                    value="male" onchange="updateProgress()">
                                Male
                            </label>
                            <label class="radio-item">
                                <input type="radio" name="gender" 
                                    value="female" onchange="updateProgress()">
                                Female
                            </label>
                            <label class="radio-item">
                                <input type="radio" name="gender" 
                                    value="other" onchange="updateProgress()">
                                Other
                            </label>
                        </div>
                    </div>

                    <!-- Interests -->
                    <div class="form-group">
                        <label>🎯 Interests (Select all that apply)</label>
                        <div class="checkbox-group">
                            <label class="checkbox-item">
                                <input type="checkbox" value="AI"> 🤖 AI
                            </label>
                            <label class="checkbox-item">
                                <input type="checkbox" value="ML"> 🧠 ML
                            </label>
                            <label class="checkbox-item">
                                <input type="checkbox" value="WebDev"> 💻 Web Dev
                            </label>
                            <label class="checkbox-item">
                                <input type="checkbox" value="DataScience"> 📊 Data Science
                            </label>
                            <label class="checkbox-item">
                                <input type="checkbox" value="Cloud"> ☁️ Cloud
                            </label>
                        </div>
                    </div>

                    <!-- Bio -->
                    <div class="form-group">
                        <label>📝 Bio (Optional)</label>
                        <textarea id="bio" rows="3" 
                            placeholder="Tell us about yourself (max 200 chars)"
                            maxlength="200"
                            oninput="updateCharCount(this)"></textarea>
                        <div class="char-counter" id="char-counter">
                            0 / 200
                        </div>
                    </div>

                    <!-- Submit -->
                    <button class="btn-submit" id="submit-btn" 
                        onclick="submitForm()">
                        Create Account 🚀
                    </button>
                </div>
            </div>
        </div>

        <!-- USERS TAB -->
        <div class="tab-content-box" id="tab-users">
            <div class="users-card">
                <div class="users-header">
                    <h3>👥 Registered Users</h3>
                    <span class="badge-count" id="user-count">0 users</span>
                </div>
                <div id="users-list">
                    <div class="empty-state">
                        <div>👤</div>
                        <p>No users registered yet</p>
                    </div>
                </div>
            </div>
        </div>

    </div>

    <script>
        // ===== TAB SWITCHING =====
        function showTab(tab) {
            document.querySelectorAll('.tab-content-box')
                .forEach(t => t.classList.remove('active'));
            document.querySelectorAll('.tab-btn')
                .forEach(b => b.classList.remove('active'));

            document.getElementById('tab-' + tab)
                .classList.add('active');
            event.target.classList.add('active');

            if (tab === 'users') loadUsers();
        }

        // ===== VALIDATION FUNCTIONS =====
        function showMsg(id, msg, type) {
            const el = document.getElementById(id);
            el.textContent = msg;
            el.className = 'validation-msg show ' + type;
        }

        function validateName(input) {
            if (input.value.length >= 3) {
                input.className = 'valid';
                showMsg('name-msg', '✅ Name looks good!', 'success');
            } else {
                input.className = 'invalid';
                showMsg('name-msg', '❌ Minimum 3 characters', 'error');
            }
            updateProgress();
        }

        function validateEmail(input) {
            const regex = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;
            if (regex.test(input.value)) {
                input.className = 'valid';
                showMsg('email-msg', '✅ Email looks good!', 'success');
            } else {
                input.className = 'invalid';
                showMsg('email-msg', '❌ Invalid email address', 'error');
            }
            updateProgress();
        }

        function validatePhone(input) {
            input.value = input.value.replace(/\D/g, '');
            if (input.value.length === 10) {
                input.className = 'valid';
                showMsg('phone-msg', '✅ Phone looks good!', 'success');
            } else {
                input.className = 'invalid';
                showMsg('phone-msg', 
                    `❌ ${input.value.length}/10 digits entered`, 'error');
            }
            updateProgress();
        }

        function validatePassword(input) {
            const val = input.value;
            const bars = ['bar1','bar2','bar3','bar4'];
            bars.forEach(b => document.getElementById(b).className = 'strength-bar');

            let strength = 0;
            if (val.length >= 8) strength++;
            if (/[A-Z]/.test(val)) strength++;
            if (/[0-9]/.test(val)) strength++;
            if (/[^A-Za-z0-9]/.test(val)) strength++;

            const labels = ['', 'Weak 😟', 'Medium 😐', 'Strong 💪', 'Very Strong 🔥'];
            const classes = ['', 'weak', 'medium', 'strong', 'strong'];

            for (let i = 0; i < strength; i++) {
                document.getElementById(bars[i]).className = 
                    'strength-bar ' + classes[strength];
            }

            document.getElementById('strength-text').textContent = 
                val.length === 0 ? 'Enter a password' : labels[strength];

            if (val.length >= 8) {
                input.className = 'valid';
                showMsg('password-msg', '✅ Password acceptable', 'success');
            } else {
                input.className = 'invalid';
                showMsg('password-msg', 
                    `❌ ${8 - val.length} more characters needed`, 'error');
            }
            updateProgress();
        }

        // ===== SHOW/HIDE PASSWORD =====
        function togglePassword() {
            const input = document.getElementById('password');
            const btn = document.getElementById('toggle-btn');
            if (input.type === 'password') {
                input.type = 'text';
                btn.textContent = '🙈';
            } else {
                input.type = 'password';
                btn.textContent = '👁️';
            }
        }

        // ===== CHARACTER COUNTER =====
        function updateCharCount(textarea) {
            const count = textarea.value.length;
            const counter = document.getElementById('char-counter');
            counter.textContent = count + ' / 200';
            counter.className = 'char-counter';
            if (count > 150) counter.classList.add('warning');
            if (count > 180) counter.classList.add('danger');
        }

        // ===== PROGRESS BAR =====
        function updateProgress() {
            let filled = 0;
            const total = 5;

            if (document.getElementById('name').classList.contains('valid')) filled++;
            if (document.getElementById('email').classList.contains('valid')) filled++;
            if (document.getElementById('phone').classList.contains('valid')) filled++;
            if (document.getElementById('password').classList.contains('valid')) filled++;
            if (document.querySelector('input[name="gender"]:checked')) filled++;

            const pct = Math.round((filled / total) * 100);
            document.getElementById('progress-bar').style.width = pct + '%';
            document.getElementById('progress-text').textContent = pct + '%';
        }

        // ===== SUBMIT FORM =====
        async function submitForm() {
            const name = document.getElementById('name').value;
            const email = document.getElementById('email').value;
            const password = document.getElementById('password').value;
            const phone = document.getElementById('phone').value;
            const gender = document.querySelector('input[name="gender"]:checked');
            const interests = [...document.querySelectorAll(
                'input[type="checkbox"]:checked')].map(c => c.value);

            const errorBox = document.getElementById('error-box');
            const successBox = document.getElementById('success-box');

            errorBox.className = 'error-box';
            successBox.className = 'success-box';

            const response = await fetch('/register', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({
                    name, email, password, phone,
                    gender: gender ? gender.value : '',
                    interests
                })
            });

            const data = await response.json();

            if (!data.success) {
                errorBox.innerHTML = data.errors
                    .map(e => `<p>⚠️ ${e}</p>`).join('');
                errorBox.className = 'error-box show';
                errorBox.scrollIntoView({ behavior: 'smooth' });
            } else {
                successBox.className = 'success-box show';
                document.getElementById('success-msg').textContent = 
                    `Welcome ${data.user.name}! Your account has been created.`;
                document.getElementById('register-form').style.opacity = '0.3';
                successBox.scrollIntoView({ behavior: 'smooth' });

                setTimeout(() => {
                    document.getElementById('register-form').style.opacity = '1';
                    document.getElementById('name').value = '';
                    document.getElementById('email').value = '';
                    document.getElementById('password').value = '';
                    document.getElementById('phone').value = '';
                    successBox.className = 'success-box';
                    updateProgress();
                }, 3000);
            }
        }

        // ===== LOAD USERS =====
        async function loadUsers() {
            const response = await fetch('/users');
            const data = await response.json();
            const list = document.getElementById('users-list');
            const count = document.getElementById('user-count');

            count.textContent = data.users.length + ' users';

            if (data.users.length === 0) {
                list.innerHTML = `
                    <div class="empty-state">
                        <div>👤</div>
                        <p>No users registered yet</p>
                    </div>`;
                return;
            }

            list.innerHTML = data.users.map(user => `
                <div class="user-card" id="user-${user.id}">
                    <div class="user-info">
                        <h5>👤 ${user.name}</h5>
                        <p>📧 ${user.email}</p>
                        <p>📱 ${user.phone} | ⚧ ${user.gender}</p>
                        <p>🎯 ${user.interests.length > 0 ? 
                            user.interests.join(', ') : 'No interests selected'}</p>
                        <p>🕐 ${user.joinedAt}</p>
                    </div>
                    <button class="btn-delete" 
                        onclick="deleteUser(${user.id})">
                        🗑️ Delete
                    </button>
                </div>
            `).join('');
        }

        // ===== DELETE USER =====
        async function deleteUser(id) {
            await fetch('/users/' + id, { method: 'DELETE' });
            document.getElementById('user-' + id).remove();
            const remaining = document.querySelectorAll('.user-card').length;
            document.getElementById('user-count').textContent = remaining + ' users';
            if (remaining === 0) {
                document.getElementById('users-list').innerHTML = `
                    <div class="empty-state">
                        <div>👤</div>
                        <p>No users registered yet</p>
                    </div>`;
            }
        }
    </script>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>